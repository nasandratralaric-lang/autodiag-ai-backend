# ================================================================
# AutoDiag AI — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ================================================================

# Application
NODE_ENV=development
PORT=3000

# ─── BASE DE DONNÉES ──────────────────────────────────────────
# Option A : URL complète (Neon, Supabase, Railway…)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option B : Variables individuelles (dev local avec Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autodiag_ai
DB_USER=postgres
DB_PASSWORD=dev_password

# ─── REDIS ────────────────────────────────────────────────────
# Option A : URL complète (Upstash → rediss://...)
# REDIS_URL=rediss://default:password@host:6380

# Option B : Variables individuelles (dev local)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_SECRET=REMPLACER_PAR_UNE_CLE_ALEATOIRE_LONGUE
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=30

# ─── GOOGLE OAUTH ─────────────────────────────────────────────
# console.cloud.google.com → Identifiants → OAuth 2.0
GOOGLE_CLIENT_ID=VOTRE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=VOTRE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# En prod : https://votre-app.onrender.com/api/auth/google/callback

# ─── INTELLIGENCE ARTIFICIELLE ────────────────────────────────
# Au moins une clé IA est requise pour le diagnostic
# Provider actif par défaut : openai
AI_PRIMARY_PROVIDER=openai

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_GEMINI_API_KEY=AIza...

# ─── STOCKAGE FICHIERS (photos, PDF) ──────────────────────────
# Cloudflare R2 (gratuit 10GB) ou AWS S3
# S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=autodiag-ai
# S3_PUBLIC_URL=https://cdn.autodiag.mg

# ─── FIREBASE ─────────────────────────────────────────────────
# console.firebase.google.com → Paramètres projet → Comptes de service
# FIREBASE_PROJECT_ID=autodiag-ai-xxxxx
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@autodiag-ai.iam.gserviceaccount.com

# ─── EMAIL ────────────────────────────────────────────────────
# Resend (gratuit 3000 emails/mois) : resend.com
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@autodiag.mg

# ─── SMS OTP ──────────────────────────────────────────────────
# Twilio ou Orange Madagascar API
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1234567890

# ─── MONITORING ───────────────────────────────────────────────
# Sentry (gratuit 5000 erreurs/mois) : sentry.io
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ─── CORS ─────────────────────────────────────────────────────
# En prod : URL de votre app Android + dashboard web si applicable
# ALLOWED_ORIGINS=https://autodiag.mg,https://app.autodiag.mg
